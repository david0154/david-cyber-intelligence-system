# =====================================================
# DAVID CYBER INTELLIGENCE SYSTEM v2.0.0
# Copy this file to .env and fill in your values
# All keys are optional — the system degrades gracefully
# =====================================================

# ── AI / LLM ─────────────────────────────────────────
# Download from: https://huggingface.co/TheBloke/Mixtral-8x7B-Instruct-v0.1-GGUF
# Place the .gguf file inside the models/ directory
LLM_MODEL_PATH=models/mixtral.gguf
LLM_MODEL_TYPE=mistral
LLM_MAX_TOKENS=512

# ── Offensive Tools ───────────────────────────────────
# OWASP ZAP — start ZAP then set the API key here
ZAP_URL=http://localhost:8080
ZAP_API_KEY=your_zap_api_key

# OpenVAS — self-hosted CVE scanner
OPENVAS_URL=https://localhost:9392
OPENVAS_USER=admin
OPENVAS_PASS=your_openvas_password

# ── SIEM / SOC ────────────────────────────────────────
WAZUH_URL=https://localhost:55000
WAZUH_USER=wazuh
WAZUH_PASS=your_wazuh_password

# ── Threat Intelligence ───────────────────────────────
SHODAN_API_KEY=your_shodan_key
VIRUSTOTAL_API_KEY=your_virustotal_key
ABUSEIPDB_API_KEY=your_abuseipdb_key
OTX_API_KEY=your_otx_key
SECURITYTRAILS_KEY=your_securitytrails_key
HIBP_API_KEY=your_hibp_key
MISP_URL=https://your-misp-instance
MISP_KEY=your_misp_auth_key
OPENCTI_URL=http://localhost:8080
OPENCTI_KEY=your_opencti_key

# ── Live Tracking ─────────────────────────────────────
OPENSKY_USER=your_opensky_username
OPENSKY_PASS=your_opensky_password
N2YO_API_KEY=your_n2yo_key
MARINETRAFFIC_KEY=your_marinetraffic_key

# ── Alerts ────────────────────────────────────────────
# Telegram bot — create via @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email (SMTP) — all four required for email alerts to work
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=alerts@yourdomain.com

# ── Cloudflare ────────────────────────────────────────
# Used for: WAF stats retrieval + real-time IP block via block_ip()
# get_zones() auto-discovers your Cloudflare zones
CLOUDFLARE_API_TOKEN=your_cloudflare_token
CLOUDFLARE_EMAIL=you@cloudflare.com

# ── Rate Limiting / Defense ───────────────────────────
# Max requests per minute per IP before auto-block
RATE_LIMIT_RPM=60

# Comma-separated country codes to geo-block (e.g. CN,RU,KP)
GEO_BLOCK_COUNTRIES=

# ── Optional / Hosted LLM fallback ───────────────────
OPENAI_API_KEY=your_openai_key

# ── Databases ─────────────────────────────────────────
POSTGRES_URL=postgresql://user:pass@localhost/david_db
ELASTICSEARCH_URL=http://localhost:9200
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=your_neo4j_password

# ── API Server ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
