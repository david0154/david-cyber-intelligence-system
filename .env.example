# =====================================================
# DAVID CYBER INTELLIGENCE SYSTEM v3.0
# Copy to .env and fill in your API keys
# =====================================================

# LLM Brain
LLM_MODEL_PATH=models/mixtral.gguf
LLM_MODEL_TYPE=mistral
LLM_MAX_TOKENS=512

# OSINT
SHODAN_API_KEY=your_shodan_key

# Tracking
MARINETRAFFIC_API_KEY=your_marinetraffic_key
N2YO_API_KEY=your_n2yo_key

# MISP
MISP_URL=https://your-misp-instance.com
MISP_KEY=your_misp_key

# OpenCTI
OPENCTI_URL=https://your-opencti-instance.com
OPENCTI_TOKEN=your_opencti_token

# OWASP ZAP
ZAP_URL=http://localhost:8080
ZAP_API_KEY=your_zap_key

# Wazuh SIEM
WAZUH_URL=https://localhost:55000
WAZUH_USER=wazuh
WAZUH_PASS=wazuh

# OpenVAS
OPENVAS_URL=https://localhost:9392
OPENVAS_USER=admin
OPENVAS_PASS=admin

# Cloudflare
CLOUDFLARE_API_TOKEN=your_cf_token
CLOUDFLARE_EMAIL=your@email.com

# Database
POSTGRES_URL=postgresql://user:password@localhost:5432/davidcyber
ELASTICSEARCH_URL=http://localhost:9200
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
ALERT_EMAIL=alert_target@gmail.com
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Server
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
